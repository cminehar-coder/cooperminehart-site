---
// CAISO hourly battery averages (MW),April 28 2026, representative CA duck-curve day
// positive = discharging to grid, negative = charging from grid
const CAISO_HOURLY = [
   1145,   608,   621,   570,  1982,  3506,  4168,  -914,
  -2940, -4161, -5918, -7320, -7965, -7281, -5837, -3928,
  -1855,  -676,  1659,  7337,  8491,  6953,  4699,  2619,
];

// Cathode pattern = 6 chars. Element letters tiled by mass ratio (excluding mobile ion).
//   LFP  FePOOO: Fe=37%, P=21%, O=42% Γזע 2+1+3 slots
//   LMFP MnPOOO: same olivine, Mn as differentiator from Fe
//   NMC811 NiNiOO: Ni=52%, O=35% Γזע 4+2 slots; Mn/Co too small to show
//   NMC111 NiMnCo: equal 1/3 each by mass Γזע 2+2+2 slots
//   Na-ion FeCNFe: Fe-CN-Fe bridge reads leftΓזעright (Prussian blue connectivity)
//   NCA  NiNiAl: Ni dominant + Al stabilizer (the NCA-defining element)
//
// Anode pattern = 6 chars. Function encoded in structure:
//   CΓפאCΓפאCΓפא graphite: C nodes linked by Γפא bonds, Li intercalates between tight layers
//   SiCCCC Si/C:     Si minority (2/6) in C matrix; alloying+intercalation mixed
//   C C C  hard-C:   same C but spaces = micropores where Na+ inserts (not intercalation)
const CHEMISTRIES = [
  {
    id: 'LFP',
    cathode: 'FePOOO',
    anode:   'CΓפאCΓפאCΓפא',
    ionSymbol: 'Γךץ',
    ionClass: 'li-ion',
    cathodeLabel: 'LiFePO4',
    ionLabel: 'Li+',
    anodeLabel: 'Graphite',
  },
  {
    id: 'LMFP',
    cathode: 'MnPOOO',
    anode:   'CΓפאCΓפאCΓפא',
    ionSymbol: 'Γךץ',
    ionClass: 'li-ion',
    cathodeLabel: 'LiMnFePO4',
    ionLabel: 'Li+',
    anodeLabel: 'Graphite',
  },
  {
    id: 'NMC811',
    cathode: 'NiNiOO',
    anode:   'SiCCCC',
    ionSymbol: 'Γךץ',
    ionClass: 'li-ion',
    cathodeLabel: 'NMC811',
    ionLabel: 'Li+',
    anodeLabel: 'Si/Graphite',
  },
  {
    id: 'NMC111',
    cathode: 'NiMnCo',
    anode:   'CΓפאCΓפאCΓפא',
    ionSymbol: 'Γךץ',
    ionClass: 'li-ion',
    cathodeLabel: 'NMC111',
    ionLabel: 'Li+',
    anodeLabel: 'Graphite',
  },
  {
    id: 'Na-ion',
    cathode: 'FeCNFe',
    anode:   'C C C ',
    ionSymbol: 'Γךק',
    ionClass: 'na-ion',
    cathodeLabel: 'Na-ion (PBA)',
    ionLabel: 'Na+',
    anodeLabel: 'Hard Carbon',
  },
  {
    id: 'NCA',
    cathode: 'NiNiAl',
    anode:   'SiCCCC',
    ionSymbol: 'Γךץ',
    ionClass: 'li-ion',
    cathodeLabel: 'NCA',
    ionLabel: 'Li+',
    anodeLabel: 'Si/Graphite',
  },
];
---

<pre
  id="battery-display"
  class="font-mono leading-relaxed select-none text-[#52B788]"
  aria-label="ASCII battery chemistry animation"
></pre>

<style>
  .li-ion { color: #52B788; font-weight: 600; }
  .na-ion { color: #F4A261; font-weight: 600; }
</style>

<script define:vars={{ CAISO_HOURLY, CHEMISTRIES }}>
  const SLOTS = 12;
  const IONS  = 3;

  const chem = CHEMISTRIES[Math.floor(Math.random() * CHEMISTRIES.length)];

  function getGridMW() {
    return CAISO_HOURLY[new Date().getHours()];
  }

  function ionRow(tick, dir, rowOffset) {
    const grid    = Array(SLOTS).fill(false);
    const spacing = Math.floor(SLOTS / IONS);
    for (let i = 0; i < IONS; i++) {
      const base = i * spacing + rowOffset;
      const pos  = ((base + tick * dir) % SLOTS + SLOTS) % SLOTS;
      grid[pos]  = true;
    }
    return grid.map(ion => ion
      ? `<span class="${chem.ionClass}">${chem.ionSymbol}</span>`
      : '┬╖'
    ).join(' ');
  }

  function buildFrame(tick, mw) {
    const isCharging = mw < 0;
    const dir        = isCharging ? 1 : -1;
    const r0 = ionRow(tick, dir, 0);
    const r1 = ionRow(tick, dir, 2);
    const r2 = ionRow(tick, dir, 1);
    const CAT   = `  ${chem.cathode}  `;
    const AN    = `  ${chem.anode}  `;
    const BLANK = '                           ';
    const e     = (r) => `  ${r}  `;
    return [
      `ΓפלΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפנ  ΓפלΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפנ  ΓפלΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפנ`,
      `Γפג          Γפג  Γפג                           Γפג  Γפג          Γפג`,
      `Γפג${CAT}Γפג  Γפג${e(r0)}Γפג  Γפג${AN}Γפג`,
      `Γפג          Γפג  Γפג${BLANK}Γפג  Γפג          Γפג`,
      `Γפג${CAT}Γפג  Γפג${e(r1)}Γפג  Γפג${AN}Γפג`,
      `Γפג          Γפג  Γפג${BLANK}Γפג  Γפג          Γפג`,
      `Γפג${CAT}Γפג  Γפג${e(r2)}Γפג  Γפג${AN}Γפג`,
      `Γפג          Γפג  Γפג                           Γפג  Γפג          Γפג`,
      `ΓפפΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפר  ΓפפΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפר  ΓפפΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפאΓפר`,
    ].join('\n');
  }

  function buildCaption(mw) {
    const isCharging = mw < 0;
    const gw = (Math.abs(mw) / 1000).toFixed(1);
    return isCharging
      ? `CAISO: charging batteries at ${gw} GW`
      : `CAISO: discharging batteries at ${gw} GW`;
  }

  const SPEED = 0.6;

  function tick() {
    const mw      = getGridMW();
    const step    = Math.floor(Date.now() / 1000 * SPEED);
    const display = document.getElementById('battery-display');
    const caption = document.getElementById('battery-caption');
    if (display) display.innerHTML = buildFrame(step, mw);
    if (caption) caption.textContent = buildCaption(mw);
  }

  tick();
  setInterval(tick, 250);
</script>
