---
import Layout from '../../layouts/Layout.astro';
import DarkHeader from '../../components/DarkHeader.astro';

const hobbies = [
  {
    slug: 'mountain-biking',
    title: 'Bikes Bikes Bikes',
    photo: '/photos/homies-on-bikes.jpeg',
    alt: 'Homies on bikes',
    caption: 'commuting, bikepacking, road riding, mountain biking, cargo bikes, bike bags, friends on bikes...',
  },
  {
    slug: 'sewing',
    title: 'Sewing & Making',
    photo: '/photos/wallet.jpeg',
    alt: 'Handmade wallet',
    caption: "The world opens up when you can cut your patterns on a laser and sew through leather, cordura, and zippers. I'll dump any patterns I make here",
  },
  {
    slug: 'van',
    title: 'The Big Brown Van',
    photo: '/photos/van.jpg',
    alt: '1985 Volkswagen Vanagon Westfalia',
    caption: 'A 1985 VW Vanagon Westfalia pulled from a salvage auction for $450, restored, engine-swapped, lived in.',
  },
];
---

<Layout
  title="Hobbies — Cooper Minehart"
  description="Mountain biking, sewing, and a 1985 VW Vanagon Westfalia build."
>
  <DarkHeader>
    <div class="max-w-5xl mx-auto px-6 pt-12 pb-10">
      <p class="section-label-light mb-3">Hobbies</p>
      <h1 class="font-serif text-4xl font-bold text-white">Outside the Lab</h1>
    </div>
  </DarkHeader>

  <div class="max-w-5xl mx-auto px-6 pt-10 pb-24">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {hobbies.map(({ slug, title, photo, alt, caption }) => (
        <a href={`/hobbies/${slug}`} class="group block">
          <div class="overflow-hidden rounded-lg mb-4 aspect-[4/3] bg-stone-100">
            <img
              src={photo}
              alt={alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <h3 class="font-serif text-lg font-semibold text-[#1a1a1a] mb-2 group-hover:text-forest-600 transition-colors">
            {title}
          </h3>
          <p class="text-sm text-[#666] leading-relaxed">{caption}</p>
        </a>
      ))}
    </div>
  </div>
</Layout>
