---
import Layout from '../layouts/Layout.astro';
import DarkHeader from '../components/DarkHeader.astro';

const projects = [
  {
    title: 'Updating BatPaC for Emerging Battery Technologies',
    description:
      'Extending Argonne National Laboratory\'s Battery Performance and Cost (BatPaC) model to incorporate cell-to-pack (CTP) architectures, dry electrode processing (Maxwell/Tesla process), LMFP cathode chemistry, and sodium-ion cell formats. Work at the intersection of techno-economic analysis and energy policy.',
  },
  {
    title: 'BEV Battery Supply Chain Analysis',
    description:
      'Analysis of the full electric vehicle battery value chain,from mining and refining through cell manufacturing and vehicle assembly,with policy analysis of IRA §45X manufacturing credits, FEOC/PFE eligibility rules, and OBBBA provisions.',
  },
  {
    title: 'PFAS Water Treatment Economics',
    description:
      'Two complementary studies: a process-based cost model for a VUV photochemistry PFAS water treatment technology (Prof. Ryan Sullivan\'s lab, CMU), and a conjoint analysis estimating willingness-to-pay for PFAS-free bottled water using MNL and CBC discrete choice methods.',
  },
  {
    title: 'Megawatt-Scale EV Charging with BESS Integration',
    description:
      'Techno-economic analysis of megawatt-scale EV charging station deployment integrated with battery energy storage systems.',
  },
];
---

<Layout
  title="Research — Cooper Minehart"
  description="Battery production cost modeling, supply chain analysis, and techno-economic research on emerging battery technologies and energy policy."
>
  <DarkHeader>
    <div class="max-w-5xl mx-auto px-6 pt-12 pb-10">
      <p class="section-label-light mb-3">Research</p>
      <h1 class="font-serif text-4xl font-bold text-white">Projects</h1>
    </div>
  </DarkHeader>

  <div class="max-w-5xl mx-auto px-6 pt-10 pb-24">
    <div class="space-y-6">
      {projects.map(({ title, description }) => (
        <div class="border border-stone-200 rounded-lg p-6 hover:border-forest-400 hover:shadow-sm transition-all">
          <h3 class="font-serif text-xl font-semibold text-[#1a1a1a] mb-3">{title}</h3>
          <p class="text-[#555] leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </div>
</Layout>
