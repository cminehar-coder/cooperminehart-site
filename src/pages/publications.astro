---
import Layout from '../layouts/Layout.astro';
import DarkHeader from '../components/DarkHeader.astro';
---

<Layout
  title="Publications — Cooper Minehart"
  description="Published research and working papers by Cooper Minehart in battery manufacturing, engine sensor fusion, and energy systems."
>
  <DarkHeader>
    <div class="max-w-5xl mx-auto px-6 pt-12 pb-10">
      <p class="section-label-light mb-3">Publications</p>
      <h1 class="font-serif text-4xl font-bold text-white">Writing &amp; Research</h1>
    </div>
  </DarkHeader>

  <div class="max-w-5xl mx-auto px-6 pt-10 pb-24">
    <p class="text-[#555] mb-8">
      <a
        href="https://scholar.google.com/citations?user=LXd0QBUAAAAJ&hl=en"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 text-forest-600 font-medium hover:underline"
      >
        Google Scholar profile →
      </a>
    </p>

    <!-- Working papers -->
    <section class="mb-14">
      <h2 class="font-serif text-2xl font-semibold text-[#1a1a1a] mb-6">Working Papers</h2>
      <ol class="space-y-6" reversed>
        <li class="flex gap-4">
          <span class="text-[#ccc] font-mono text-sm pt-0.5 shrink-0 w-5">1.</span>
          <div>
            <p class="text-[#1a1a1a] leading-relaxed">
              <strong>C. Heyne Minehart.</strong> "Updating BatPaC for Emerging Battery Technologies:
              Dry Electrode Processing, Cell-to-Pack Architectures, LMFP, and Sodium-Ion."
              <em>PhD Qualifying Paper, Carnegie Mellon University</em>, in preparation.
            </p>
            <p class="text-sm text-[#888] mt-1">
              Techno-economic analysis of next-generation battery manufacturing processes and their
              implications for BEV cost projections and energy policy.
            </p>
          </div>
        </li>
      </ol>
    </section>

    <!-- Peer-reviewed -->
    <section class="mb-14">
      <h2 class="font-serif text-2xl font-semibold text-[#1a1a1a] mb-6">Peer-Reviewed Publications</h2>
      <ol class="space-y-8" reversed>
        <li class="flex gap-4">
          <span class="text-[#ccc] font-mono text-sm pt-0.5 shrink-0 w-5">2.</span>
          <div>
            <p class="text-[#1a1a1a] leading-relaxed">
              <strong>C. Heyne Minehart</strong>, J. R. Blough, J. D. Naber, C. Glugla, and C. Archer.
              "Sensor Fusion Approach for Dynamic Torque Estimation with Low Cost Sensors for Boosted
              4-Cylinder Engine."
              <em>SAE World Congress</em>, 2021.
            </p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="text-[#ccc] font-mono text-sm pt-0.5 shrink-0 w-5">1.</span>
          <div>
            <p class="text-[#1a1a1a] leading-relaxed">
              <strong>C. Heyne Minehart.</strong>
              "Data Driven Sensor Fusion for Cycle to Cycle IMEP Estimation."
              <em>Master's Thesis, Michigan Technological University</em>, 2020.
            </p>
          </div>
        </li>
      </ol>
    </section>

    <div class="border-t border-stone-200 pt-8">
      <p class="text-sm text-[#888]">
        Additional working papers and reports available on request.
      </p>
    </div>
  </div>
</Layout>
