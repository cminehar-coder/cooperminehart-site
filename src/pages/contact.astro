---
import Layout from '../layouts/Layout.astro';
import DarkHeader from '../components/DarkHeader.astro';
---

<Layout
  title="Contact — Cooper Minehart"
  description="Get in touch with Cooper Minehart for research inquiries, collaboration, or general correspondence."
>
  <DarkHeader>
    <div class="max-w-5xl mx-auto px-6 pt-12 pb-10">
      <p class="section-label-light mb-3">Contact</p>
      <h1 class="font-serif text-4xl font-bold text-white">Get in Touch</h1>
    </div>
  </DarkHeader>

  <div class="max-w-5xl mx-auto px-6 pt-10 pb-24">
    <div class="max-w-sm space-y-5 text-sm">
      <div>
        <p class="text-xs font-mono text-[#888] uppercase tracking-wider mb-1">Email</p>
        <a href="mailto:cminehar@andrew.cmu.edu" class="text-forest-600 hover:underline font-medium">
          cminehar@andrew.cmu.edu
        </a>
      </div>
      <div>
        <p class="text-xs font-mono text-[#888] uppercase tracking-wider mb-1">Google Scholar</p>
        <a href="https://scholar.google.com/citations?user=LXd0QBUAAAAJ&hl=en" target="_blank" rel="noopener" class="text-forest-600 hover:underline font-medium">
          scholar.google.com
        </a>
      </div>
      <div>
        <p class="text-xs font-mono text-[#888] uppercase tracking-wider mb-1">LinkedIn</p>
        <a href="https://linkedin.com/in/cooper-minehart/" target="_blank" rel="noopener" class="text-forest-600 hover:underline font-medium">
          linkedin.com/in/cooper-minehart
        </a>
      </div>
      <div>
        <p class="text-xs font-mono text-[#888] uppercase tracking-wider mb-1">Institution</p>
        <p class="text-[#555]">
          Department of Engineering &amp; Public Policy<br />
          Carnegie Mellon University<br />
          Pittsburgh, PA
        </p>
      </div>
    </div>
  </div>
</Layout>
